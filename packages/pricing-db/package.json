{
  "name": "@inferwise/pricing-db",
  "version": "0.1.0",
  "description": "Maintained pricing database for LLM providers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers/*": "./providers/*"
  },
  "files": ["dist", "providers", "schema.json", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://inferwise.dev",
  "bugs": {
    "url": "https://github.com/inferwise/inferwise/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inferwise/inferwise",
    "directory": "packages/pricing-db"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["llm", "pricing", "tokens", "cost", "ai", "models", "finops"],
  "author": "Peter Kim",
  "license": "Apache-2.0",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
