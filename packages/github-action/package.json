{
  "name": "@inferwise/github-action",
  "version": "1.0.0",
  "description": "GitHub Action for Inferwise — posts LLM cost diff comments on pull requests",
  "type": "module",
  "main": "./dist/index.cjs",
  "files": ["dist", "action.yml", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://inferwise.dev",
  "bugs": {
    "url": "https://github.com/inferwise/inferwise/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inferwise/inferwise",
    "directory": "packages/github-action"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["github-action", "llm", "cost", "finops", "ai", "devtools"],
  "author": "Peter Kim",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@inferwise/pricing-db": "workspace:*",
    "inferwise": "workspace:*",
    "chalk": "^5.3.0",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vercel/ncc": "^0.38.4",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
