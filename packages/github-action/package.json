{
  "name": "@inferwise/github-action",
  "version": "0.0.1",
  "description": "GitHub Action for Inferwise — posts LLM cost diff comments on pull requests",
  "type": "module",
  "main": "./dist/index.js",
  "files": ["dist", "action.yml", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://inferwise.dev",
  "bugs": {
    "url": "https://github.com/inferwise/inferwise/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inferwise/inferwise",
    "directory": "packages/github-action"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --no-splitting --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^6.0.0",
    "@inferwise/pricing-db": "workspace:*",
    "chalk": "^5.3.0",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
