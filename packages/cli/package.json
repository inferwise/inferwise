{
  "name": "inferwise",
  "version": "0.0.1",
  "description": "Know your LLM costs before you commit.",
  "bin": {
    "inferwise": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --banner.js '#!/usr/bin/env node'",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["llm", "tokens", "cost", "finops", "ai", "cli"],
  "author": "Peter Kim",
  "license": "Apache-2.0",
  "dependencies": {
    "@inferwise/pricing-db": "workspace:*",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "glob": "^11.0.0",
    "simple-git": "^3.22.0",
    "tiktoken": "^1.0.17",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
