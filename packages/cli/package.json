{
  "name": "inferwise",
  "version": "0.1.0",
  "description": "Know and control your LLM costs before they ship.",
  "type": "module",
  "bin": {
    "inferwise": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://inferwise.dev",
  "bugs": {
    "url": "https://github.com/inferwise/inferwise/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inferwise/inferwise",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["llm", "tokens", "cost", "finops", "ai", "cli"],
  "author": "Peter Kim",
  "license": "Apache-2.0",
  "dependencies": {
    "@inferwise/pricing-db": "workspace:*",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "glob": "^11.0.0",
    "simple-git": "^3.22.0",
    "tiktoken": "^1.0.17",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
